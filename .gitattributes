# Git LFS - track large binary files
# This pushes them to GitHub's LFS storage instead of regular git, bypassing
# the 100MB file-size limit. The 165MB trained ResNet50 model is tracked here.
# Hugging Face Hub also requires all binary files to use LFS.

# Trained Keras / TF model
*.h5   filter=lfs diff=lfs merge=lfs -text
*.keras filter=lfs diff=lfs merge=lfs -text
*.pb   filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text

# Large model weights / checkpoints
*.weights filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Pickled Python objects (sklearn, etc.)
*.pkl  filter=lfs diff=lfs merge=lfs -text
*.joblib filter=lfs diff=lfs merge=lfs -text

# Images (required by Hugging Face Hub)
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif  filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.svg  filter=lfs diff=lfs merge=lfs -text

# PDFs / documents
*.pdf  filter=lfs diff=lfs merge=lfs -text

# Audio / video (just in case)
*.mp3  filter=lfs diff=lfs merge=lfs -text
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.wav  filter=lfs diff=lfs merge=lfs -text
